# API key for Anthropic Claude models
ANTHROPIC_API_KEY=

# OpenAI (optional — required only if using OpenAI models)
OPENAI_API_KEY=

# Runtime environment (accepted values: development, staging, production)
APP_ENV=

# Logging verbosity level (e.g. DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=

# API key for LangSmith tracing and evaluation
LANGSMITH_API_KEY=

# LangSmith project name to group traces under
LANGSMITH_PROJECT=

# Database
POSTGRES_USER=evalforge
POSTGRES_PASSWORD=evalforge_dev
POSTGRES_DB=evalforge
# Nota: ao rodar via docker-compose, substitua localhost pelo nome do serviço (postgres)
DATABASE_URL=postgresql+asyncpg://evalforge:evalforge_dev@localhost:5432/evalforge
DATABASE_READER_URL=postgresql+asyncpg://evalforge:evalforge_dev@localhost:5432/evalforge

# Redis
# Nota: ao rodar via docker-compose, substitua localhost pelo nome do serviço (redis)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
